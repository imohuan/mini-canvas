{
  "name": "prosemirror-editor-bundle",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/prosemirror-editor.umd.js"
    },
    "./style.css": "./src/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && pnpm run build:types",
    "build:standalone": "vite build --mode webcomponent",
    "build:vue-webcomponent": "vite build --mode webcomponent-vue",
    "build:all": "pnpm run build && pnpm run build:standalone && pnpm run build:vue-webcomponent",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "preview": "vite preview"
  },
  "dependencies": {
    "prosemirror-commands": "^1.6.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.23.0",
    "prosemirror-schema-basic": "^1.2.3",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.35.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.1",
    "vue-tsc": "^2.2.0"
  }
}